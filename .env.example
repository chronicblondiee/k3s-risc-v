# Copy to .env (gitignored — never commit the real file), chmod it 0600,
# fill in your real sudo password, then before running ansible-playbook:
#   chmod 0600 .env
#   set -a; source .env; set +a
# group_vars/all/local.yml picks this up automatically as the become
# password for any playbook run, so become-requiring tasks (e.g. the
# password rotation in playbooks/02_base_config.yml) no longer need
# --ask-become-pass typed in interactively every time.
ANSIBLE_BECOME_PASSWORD=CHANGE_ME

# k3s HA API endpoint and TLS SANs, consumed by group_vars/all/cluster.yml.
# K3S_API_ENDPOINT must be a LAN-resolvable DNS name (or VIP) for the k3s
# API; K3S_API_TLS_SANS is a comma-separated list of every name/IP the API
# certificate should cover — include the endpoint, each server's IP, and
# each server's hostname (also list planned future servers so the cert
# already covers them when they join).
K3S_API_ENDPOINT=k3s.example.lan
K3S_API_TLS_SANS=k3s.example.lan,192.168.1.102,192.168.1.103,192.168.1.104,k8s-rv2-01,k8s-rv2-02,k8s-rv2-03
