apiVersion: v1
kind: Namespace
metadata:
  name: {{ registry_namespace_effective }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: riscv64-registry-data
  namespace: {{ registry_namespace_effective }}
spec:
  accessModes: [ReadWriteOnce]
  storageClassName: local-path
  resources:
    requests:
      storage: {{ registry_storage_size_effective }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: riscv64-registry
  namespace: {{ registry_namespace_effective }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: riscv64-registry
  template:
    metadata:
      labels:
        app: riscv64-registry
    spec:
      nodeSelector:
        kubernetes.io/hostname: {{ registry_node_name }}
      containers:
        - name: registry
          image: {{ registry_image_effective }}
          ports:
            - containerPort: 5000
          volumeMounts:
            - name: data
              mountPath: /var/lib/registry
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: riscv64-registry-data
---
apiVersion: v1
kind: Service
metadata:
  name: riscv64-registry
  namespace: {{ registry_namespace_effective }}
spec:
  type: NodePort
  selector:
    app: riscv64-registry
  ports:
    - port: 5000
      targetPort: 5000
      nodePort: {{ registry_node_port_effective }}
