vrrp_script chk_k3s {
    script "/usr/local/bin/check-k3s-api.sh"
    interval 5
    weight -30
    fall 2
    rise 2
}

vrrp_instance VI_1 {
    state BACKUP
    interface {{ k3s_vip_interface }}
    virtual_router_id {{ k3s_vip_router_id_effective }}
    priority {{ k3s_vip_priority }}
    advert_int 1
    # Gives the VIP a constant MAC (00:00:5e:00:01:<virtual_router_id>,
    # decimal-to-hex) regardless of which physical node currently holds
    # it, via a dedicated vrrp<id> pseudo-interface - needed so a router
    # DHCP reservation/exclusion for the VIP address has a stable MAC to
    # bind to. vmac_xmit_base keeps VRRP protocol advertisements on the
    # real interface for reliability; only ARP/gratuitous-ARP for the VIP
    # itself uses the virtual MAC.
    use_vmac
    vmac_xmit_base
    authentication {
        auth_type PASS
        auth_pass {{ k3s_vip_auth_pass_effective }}
    }
    virtual_ipaddress {
        {{ k3s_vip_address_effective }}/24
    }
    track_script {
        chk_k3s
    }
}
